@model ClientRelationshipManagement.Web.Models.Emails.EmailsPageViewModel
@{
    ViewData["Title"] = "Emails";
    string gridUrl = Url.Action("Index", new
    {
        Model.Search,
        state = Model.StateFilter,
        Model.Page,
        Model.PageSize
    })!;
}

<main class="page-shell email-page">
    <section class="page-hero">
        <div>
            <h1>Emails</h1>
            <p class="lede">Review queued, approved, sent, and failed commercial email activity.</p>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.Notice))
    {
        <section class="notice-banner">
            <strong>Email queue</strong>
            <p>@Model.Notice</p>
        </section>
    }

    <section class="dashboard-overview email-overview">
        <div class="stats-rail stats-rail--primary">
            <article class="metric-pill metric-pill--primary">
                <span>Total Emails</span>
                <strong>@Model.TotalEmails</strong>
            </article>
            <article class="metric-pill metric-pill--primary">
                <span>Draft Or Failed</span>
                <strong>@Model.DraftEmails</strong>
            </article>
            <article class="metric-pill metric-pill--primary">
                <span>Approved Or Sending</span>
                <strong>@Model.ApprovedEmails</strong>
            </article>
            <article class="metric-pill metric-pill--primary">
                <span>Sent</span>
                <strong>@Model.SentEmails</strong>
            </article>
        </div>
    </section>

    <section class="data-panel">
        <form method="get" class="filter-bar">
            <label class="auth-field auth-field--full">
                <span>Search</span>
                <input type="search" name="search" value="@Model.Search" placeholder="Search by client, subject, or recipient" />
            </label>

            <label class="auth-field">
                <span>State</span>
                <select name="state" asp-items="Model.StateOptions"></select>
            </label>

            <label class="auth-field">
                <span>Rows</span>
                <select name="pageSize">
                    @foreach (int size in new[] { 25, 50, 100 })
                    {
                        <option value="@size" selected="@(Model.PageSize == size)">@size</option>
                    }
                </select>
            </label>

            <div class="filter-bar__actions">
                <button type="submit" class="primary-action">Filter</button>
                <a class="secondary-action" href="/Admin/Emails">Reset</a>
            </div>
        </form>

        @if (Model.Emails.Count == 0)
        {
            <div class="empty-state empty-state--compact">
                <strong>No emails match the current filter.</strong>
                <p>Drafts approved from scheduled actions and client communications will appear here.</p>
            </div>
        }
        else
        {
            <div class="company-results-toolbar email-results-toolbar">
                <p>Showing @Model.FirstItem.ToString("N0")–@Model.LastItem.ToString("N0") of @Model.TotalCount.ToString("N0") emails</p>
                <span>Page @Model.Page.ToString("N0") of @Model.TotalPages.ToString("N0")</span>
            </div>

            <div class="table-shell email-table-shell">
                <table class="crm-table email-table">
                    <thead>
                        <tr>
                            <th>Client</th>
                            <th>State</th>
                            <th>To</th>
                            <th>Subject</th>
                            <th>Scheduled</th>
                            <th>Sent</th>
                            <th>Created</th>
                            <th class="table-actions">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var email in Model.Emails)
                        {
                            string dialogId = $"email-{email.Id}";
                            <tr>
                                <td><a href="/Clients/Edit/@email.ClientId">@email.ClientName</a></td>
                                <td>@email.StateLabel</td>
                                <td>@(string.IsNullOrWhiteSpace(email.ToAddresses) ? "Recipient pending" : email.ToAddresses)</td>
                                <td>@email.Subject</td>
                                <td>@email.ScheduledSendLabel</td>
                                <td>@(string.IsNullOrWhiteSpace(email.SentOnLabel) ? "Not sent" : email.SentOnLabel)</td>
                                <td>@email.CreatedOnLabel</td>
                                <td class="table-actions">
                                    <div class="inline-actions">
                                        <button type="button" class="secondary-action" data-open-dialog="@dialogId">View</button>
                                        @if (email.CanMarkSent)
                                        {
                                            <form asp-action="MarkSent" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="ClientId" value="@email.ClientId" />
                                                <input type="hidden" name="EmailId" value="@email.Id" />
                                                <input type="hidden" name="ReturnUrl" value="@gridUrl" />
                                                <button type="submit" class="secondary-action">Mark Sent</button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>

                            <dialog id="@dialogId" class="crm-dialog crm-dialog--email">
                                <div class="crm-dialog__header">
                                    <div>
                                        <h3>Email to @email.ClientName</h3>
                                        <p>@email.StateLabel</p>
                                    </div>
                                    <button type="button" class="crm-dialog__close" data-close-dialog="@dialogId">Close</button>
                                </div>
                                <div class="crm-dialog__body">
                                    <div class="crm-dialog__meta">
                                        <span class="queue-count">From: @(string.IsNullOrWhiteSpace(email.FromEmailAddress) ? "Sender pending" : $"{email.FromDisplayName} <{email.FromEmailAddress}>")</span>
                                        <span class="queue-count">To: @(string.IsNullOrWhiteSpace(email.ToAddresses) ? "Recipient pending" : email.ToAddresses)</span>
                                        <span class="queue-count">@email.ScheduledSendLabel</span>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(email.LastError))
                                    {
                                        <section class="notice-banner notice-banner--embedded">
                                            <strong>Last send error</strong>
                                            <p>@email.LastError</p>
                                        </section>
                                    }
                                    @if (email.CanApprove)
                                    {
                                        <form asp-action="ReviewAndApprove" method="post" class="crm-form crm-form--compact">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="ClientId" value="@email.ClientId" />
                                            <input type="hidden" name="EmailId" value="@email.Id" />
                                            <input type="hidden" name="ReturnUrl" value="@gridUrl" />
                                            <div class="form-grid">
                                                <label class="auth-field auth-field--full">
                                                    <span>Subject</span>
                                                    <input name="Subject" value="@email.Subject" required />
                                                </label>
                                                <label class="auth-field auth-field--full auth-field--multiline email-review-body">
                                                    <span>Email content</span>
                                                    <textarea name="Body" required>@email.Preview</textarea>
                                                </label>
                                                <label class="auth-field auth-field--full">
                                                    <span>Scheduled Send On</span>
                                                    <input name="ScheduledSendOn" type="datetime-local" value="@email.ScheduledSendValue" />
                                                </label>
                                            </div>
                                            <div class="form-actions form-actions--start">
                                                <button type="submit" class="primary-action">Approve Send</button>
                                                @if (email.CanReject)
                                                {
                                                    <button type="button" class="secondary-action" data-open-dialog="reject-@email.Id" data-close-before-open>Reject</button>
                                                }
                                            </div>
                                        </form>
                                    }
                                    else
                                    {
                                        <div class="mail-message">
                                            <strong>@email.Subject</strong>
                                            <div class="crm-dialog__content">@email.Preview</div>
                                        </div>
                                    }
                                </div>
                            </dialog>

                            @if (email.CanReject)
                            {
                                <dialog id="reject-@email.Id" class="crm-dialog">
                                    <div class="crm-dialog__header">
                                        <div>
                                            <h3>Reject email</h3>
                                            <p>Explain what is wrong so the Approval Agent can trace and improve the source process.</p>
                                        </div>
                                        <button type="button" class="crm-dialog__close" data-close-dialog="reject-@email.Id">Close</button>
                                    </div>
                                    <div class="crm-dialog__body">
                                        <form asp-action="Reject" method="post" class="crm-form crm-form--compact">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="ClientId" value="@email.ClientId" />
                                            <input type="hidden" name="EmailId" value="@email.Id" />
                                            <input type="hidden" name="ReturnUrl" value="@gridUrl" />
                                            <div class="form-grid">
                                                <label class="auth-field auth-field--full auth-field--multiline">
                                                    <span>Reason for rejection</span>
                                                    <textarea name="Reason" minlength="5" required placeholder="Explain the problem, or ask the agent to suggest something better."></textarea>
                                                </label>
                                            </div>
                                            <div class="form-actions form-actions--start">
                                                <button type="submit" class="primary-action">Reject and open conversation</button>
                                            </div>
                                        </form>
                                    </div>
                                </dialog>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <nav class="company-pager email-pager" aria-label="Email result pages">
                <a class="secondary-action @(Model.HasPreviousPage ? "" : "is-disabled")"
                   aria-disabled="@(!Model.HasPreviousPage)"
                   href="@(Model.HasPreviousPage ? Url.Action("Index", new { Model.Search, state = Model.StateFilter, page = Model.Page - 1, Model.PageSize }) : null)">Previous</a>
                <span>Page @Model.Page.ToString("N0")</span>
                <a class="secondary-action @(Model.HasNextPage ? "" : "is-disabled")"
                   aria-disabled="@(!Model.HasNextPage)"
                   href="@(Model.HasNextPage ? Url.Action("Index", new { Model.Search, state = Model.StateFilter, page = Model.Page + 1, Model.PageSize }) : null)">Next</a>
            </nav>
        }
    </section>
</main>

<script>
    (() => {
        const openButtons = document.querySelectorAll("[data-open-dialog]");
        const closeButtons = document.querySelectorAll("[data-close-dialog]");

        openButtons.forEach(button => {
            button.addEventListener("click", () => {
                if (button.hasAttribute("data-close-before-open")) {
                    button.closest("dialog")?.close();
                }
                document.getElementById(button.dataset.openDialog)?.showModal();
            });
        });

        closeButtons.forEach(button => {
            button.addEventListener("click", () => {
                document.getElementById(button.dataset.closeDialog)?.close();
            });
        });

        document.querySelectorAll(".crm-dialog").forEach(dialog => {
            dialog.addEventListener("click", event => {
                const bounds = dialog.getBoundingClientRect();
                const isInside =
                    event.clientX >= bounds.left &&
                    event.clientX <= bounds.right &&
                    event.clientY >= bounds.top &&
                    event.clientY <= bounds.bottom;

                if (!isInside) {
                    dialog.close();
                }
            });
        });

        const linkedDialogId = window.location.hash.slice(1);
        if (linkedDialogId) {
            document.getElementById(linkedDialogId)?.showModal();
        }
    })();
</script>
