@model OpportunitiesPageViewModel
@{
    ViewData["Title"] = "Opportunities";
    string taskFilterLabel = Model.TaskFilter switch
    {
        "open" => "Open actions",
        "due-today" => "Actions due today",
        "overdue" => "Overdue actions",
        _ => string.Empty
    };
}

<main class="page-shell">
    <section class="page-hero">
        <div>
            <h1>Opportunities</h1>
            <p class="lede">
                Track live opportunities, monitor the next scheduled action, and jump into the
                client workspace when a commercial decision needs attention.
            </p>
        </div>

        <div class="page-hero__actions">
            <span class="queue-count">@Model.TotalOpportunities matching opportunities</span>
            @if (taskFilterLabel.Length > 0)
            {
                <span class="queue-count">@taskFilterLabel</span>
            }
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.Notice))
    {
        <section class="notice-banner">
            <strong>Opportunities update</strong>
            <p>@Model.Notice</p>
        </section>
    }

    <section class="data-panel">
        <div class="section-heading">
            <div>
                <h2>Opportunity pipeline</h2>
            </div>
        </div>

        <form method="get" class="filter-bar">
            @if (!string.IsNullOrWhiteSpace(Model.Scope))
            {
                <input type="hidden" name="scope" value="@Model.Scope" />
            }
            @if (!string.IsNullOrWhiteSpace(Model.TaskFilter))
            {
                <input type="hidden" name="tasks" value="@Model.TaskFilter" />
            }
            <label class="auth-field">
                <span>Search</span>
                <input type="search" name="search" value="@Model.Search" placeholder="Company, contact, type, next action" />
            </label>

            <label class="auth-field">
                <span>Stage</span>
                <select name="stage" asp-items="Model.StageOptions"></select>
            </label>

            <label class="auth-field">
                <span>Relationship</span>
                <select name="status" asp-items="Model.StatusOptions"></select>
            </label>

            <label class="auth-field">
                <span>Sort By</span>
                <select name="sort" asp-items="Model.SortOptions"></select>
            </label>

            <div class="filter-bar__actions">
                <button type="submit" class="primary-action">Apply</button>
                <a class="secondary-action" href="/Opportunities">Reset</a>
            </div>
        </form>

        @if (Model.Opportunities.Count == 0)
        {
            <div class="empty-state">
                <strong>No opportunities match the current filter.</strong>
                <p>Qualified leads will appear here once outreach is underway.</p>
            </div>
        }
        else
        {
            <div class="table-shell">
                <table class="crm-table">
                    <thead>
                        <tr>
                            <th class="tree-grid__toggle-column"><span class="sr-only">Expand</span></th>
                            <th>Company</th>
                            <th>Relationship</th>
                            <th>Stage</th>
                            <th>Type</th>
                            <th>Primary Contact</th>
                            <th>Value</th>
                            <th>Probability</th>
                            <th>Next Action</th>
                            <th>Due</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (OpportunityListItemViewModel opportunity in Model.Opportunities)
                        {
                            <tr>
                                <td class="tree-grid__toggle-cell"><button type="button" class="tree-grid__toggle" data-detail-expand="opportunity-@opportunity.Id" data-detail-url="/Opportunities/@opportunity.Id/Details" aria-expanded="false" aria-label="Expand @opportunity.CompanyName"><span aria-hidden="true"></span></button></td>
                                <td>@opportunity.CompanyName</td>
                                <td>@opportunity.RelationshipStatusLabel</td>
                                <td>@opportunity.StageLabel</td>
                                <td>@opportunity.TypeLabel</td>
                                <td>@opportunity.PrimaryContactName</td>
                                <td>@opportunity.EstimatedAnnualValueLabel</td>
                                <td>@opportunity.ProbabilityLabel</td>
                                <td>@(string.IsNullOrWhiteSpace(opportunity.NextAction) ? "None set" : opportunity.NextAction)</td>
                                <td>@opportunity.NextActionDueLabel</td>
                            </tr>
                            <tr class="tree-grid__detail-row" data-detail-row="opportunity-@opportunity.Id" hidden><td colspan="10"><div class="tree-grid__detail-host" data-detail-host="opportunity-@opportunity.Id"></div></td></tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</main>

<script>
    (() => {
        const initialiseTabs = (host) => host.querySelectorAll("[data-detail-tab]").forEach((tab) => tab.addEventListener("click", () => {
            host.querySelectorAll("[data-detail-tab]").forEach((candidate) => {
                const active = candidate === tab;
                candidate.classList.toggle("is-active", active);
                candidate.setAttribute("aria-selected", active ? "true" : "false");
            });
            host.querySelectorAll("[data-detail-panel]").forEach((panel) => panel.hidden = panel.dataset.detailPanel !== tab.dataset.detailTab);
        }));
        document.querySelectorAll("[data-detail-expand]").forEach((button) => button.addEventListener("click", async () => {
            const key = button.dataset.detailExpand;
            const row = document.querySelector(`[data-detail-row="${key}"]`);
            const host = row.querySelector("[data-detail-host]");
            const opening = row.hidden;
            row.hidden = !opening;
            button.setAttribute("aria-expanded", opening ? "true" : "false");
            if (!opening || host.dataset.loaded === "true") return;
            host.innerHTML = '<p class="crm-muted">Loading details…</p>';
            try {
                const response = await fetch(button.dataset.detailUrl, { headers: { "X-Requested-With": "XMLHttpRequest" } });
                if (!response.ok) throw new Error();
                host.innerHTML = await response.text();
                host.dataset.loaded = "true";
                initialiseTabs(host);
            } catch {
                host.innerHTML = '<div class="empty-state empty-state--compact"><strong>Details could not be loaded.</strong><p>Collapse and try again.</p></div>';
            }
        }));
    })();
</script>
