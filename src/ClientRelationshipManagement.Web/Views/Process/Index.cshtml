@model ProcessIndexPageViewModel
@{
    ViewData["Title"] = "Process";
}

<main class="page-shell">
    <section class="page-hero">
        <div>
            <h1>Process</h1>
            <p class="lede">
                Maintain the reusable workflow definitions that drive lead qualification,
                opportunity progression, and client onboarding across the ClientRelationshipManagement.Web.
            </p>
        </div>

        <div class="page-hero__actions">
            <button type="button" class="primary-action" onclick="document.getElementById('createProcessDialog').showModal()">New process</button>
            <a class="secondary-action" href="/Documentation/Pages/Process-Page">Process Notes</a>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.Notice))
    {
        <section class="notice-banner">
            <strong>Process designer</strong>
            <p>@Model.Notice</p>
        </section>
    }

    <section class="data-panel">
        <div class="section-heading">
            <div>
                <h2>Process List</h2>
            </div>
        </div>

        @if (Model.Definitions.Count == 0)
        {
            <div class="empty-state">
                <strong>No process definitions are available.</strong>
                <p>Create the first process to start driving automation.</p>
            </div>
        }
        else
        {
            <div class="table-shell">
                <table class="crm-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Scope</th>
                            <th>Tenant</th>
                            <th>Default</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (ProcessDefinitionSummaryViewModel definition in Model.Definitions)
                        {
                            <tr>
                                <td>@definition.Name</td>
                                <td>@DisplayText.Humanize(definition.ScopeType)</td>
                                <td>@definition.TenantId</td>
                                <td>@(definition.IsDefault ? "Yes" : "No")</td>
                                <td>@(definition.IsActive ? "Active" : "Inactive")</td>
                                <td class="table-actions">
                                    <a class="secondary-action" href="/Process/Edit/@definition.Id">Edit</a>
                                    <form asp-action="DeleteDefinition" method="post" class="inline-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@definition.Id" />
                                        <button type="submit" class="secondary-action">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</main>

<dialog id="createProcessDialog" class="crm-dialog crm-dialog--wide">
    <div class="crm-dialog__header">
        <div>
            <h3>Create Process</h3>
            <p>Add a reusable workflow definition for a lead, opportunity, or client account scope.</p>
        </div>
        <button type="button" class="crm-dialog__close" onclick="document.getElementById('createProcessDialog').close()">Close</button>
    </div>

    <div class="crm-dialog__body">
        <form asp-action="SaveDefinition" method="post" class="crm-form crm-form--compact">
            @Html.AntiForgeryToken()
            <div class="form-grid">
                <label class="auth-field">
                    <span>Tenant</span>
                    <input name="TenantId" value="@Model.NewDefinition.TenantId" />
                </label>
                <label class="auth-field">
                    <span>Scope</span>
                    <select name="ScopeType" asp-items="Model.NewDefinition.ScopeTypeOptions"></select>
                </label>
                <label class="auth-field auth-field--full">
                    <span>Name</span>
                    <input name="Name" value="@Model.NewDefinition.Name" required />
                </label>
                <label class="auth-field auth-field--full auth-field--multiline">
                    <span>Description</span>
                    <textarea name="Description">@Model.NewDefinition.Description</textarea>
                </label>
                <label class="checkbox-field">
                    <input name="IsDefault" type="checkbox" value="true" checked="@Model.NewDefinition.IsDefault" />
                    <span>Default process</span>
                </label>
                <label class="checkbox-field">
                    <input name="IsActive" type="checkbox" value="true" checked="@Model.NewDefinition.IsActive" />
                    <span>Active</span>
                </label>
            </div>
            <div class="form-actions">
                <button type="submit" class="primary-action">Create process</button>
            </div>
        </form>
    </div>
</dialog>
