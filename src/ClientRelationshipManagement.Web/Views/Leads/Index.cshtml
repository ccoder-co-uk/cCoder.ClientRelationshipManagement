@model ClientRelationshipManagement.Web.Models.Leads.LeadsPageViewModel
@{
    ViewData["Title"] = "Leads";
}

<main class="page-shell">
    <section class="page-hero">
        <div>
            <h1>Leads</h1>
            <p class="lede">
                Review imported and manually added leads, then qualify the raw records before the
                workflow turns them into trusted companies and live opportunities.
            </p>
        </div>

        <div class="page-hero__actions">
            <button type="button" class="primary-action" onclick="document.getElementById('newLeadDialog').showModal()">New Lead</button>
            <a class="secondary-action" href="/Imports">Bulk Import</a>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.Notice))
    {
        <section class="notice-banner">
            <strong>Lead intake</strong>
            <p>@Model.Notice</p>
        </section>
    }

    <section class="data-panel">
        <div class="section-heading">
            <div>
                <h2>Lead Queue</h2>
            </div>
        </div>

        <form method="get" class="filter-bar">
            <label class="auth-field auth-field--full">
                <span>Search</span>
                <input type="search" name="search" value="@Model.Search" placeholder="Company, contact, source, tenant" />
            </label>

            <label class="auth-field">
                <span>Status</span>
                <select name="status" asp-items="Model.StatusOptions"></select>
            </label>

            <div class="filter-bar__actions">
                <button type="submit" class="primary-action">Filter</button>
                <a class="secondary-action" href="/Leads">Reset</a>
            </div>
        </form>

        @if (Model.Leads.Count == 0)
        {
            <div class="empty-state">
                <strong>No leads match the current filter.</strong>
                <p>Imported and manually created leads will appear here.</p>
            </div>
        }
        else
        {
            <div class="table-shell">
                <table class="crm-table">
                    <thead>
                        <tr>
                            <th>Company</th>
                            <th>Status</th>
                            <th>Source</th>
                            <th>Contact</th>
                            <th>Tenant</th>
                            <th>Linked</th>
                            <th>Created</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lead in Model.Leads)
                        {
                            <tr>
                                <td>@lead.CompanyName</td>
                                <td>@lead.StatusLabel</td>
                                <td>@lead.SourceSystem</td>
                                <td>@(string.IsNullOrWhiteSpace(lead.ContactName) ? "Not set" : lead.ContactName)</td>
                                <td>@lead.TenantId</td>
                                <td>@lead.LinkedCompanyLabel</td>
                                <td>@lead.CreatedOnLabel</td>
                                <td class="table-actions">
                                    <a class="secondary-action" href="/Leads/Edit/@lead.Id">View lead</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</main>

<dialog id="newLeadDialog" class="crm-dialog crm-dialog--wide">
    <div class="crm-dialog__header">
        <div>
            <h3>New Lead</h3>
            <p>Create a single lead record and let the workflow take over from there.</p>
        </div>
        <button type="button" class="crm-dialog__close" onclick="document.getElementById('newLeadDialog').close()">Close</button>
    </div>

    <div class="crm-dialog__body">
        <form asp-action="Create" method="post" class="crm-form crm-form--compact">
            @Html.AntiForgeryToken()
            <div class="form-grid">
                <label class="auth-field">
                    <span>Tenant</span>
                    <input asp-for="NewLead.TenantId" />
                </label>

                <label class="auth-field">
                    <span>Source System</span>
                    <input asp-for="NewLead.SourceSystem" />
                </label>

                <label class="auth-field auth-field--full">
                    <span>Company Name</span>
                    <input asp-for="NewLead.RawCompanyName" />
                </label>

                <label class="auth-field">
                    <span>Trading Name</span>
                    <input asp-for="NewLead.RawTradingName" />
                </label>

                <label class="auth-field">
                    <span>Company Number</span>
                    <input asp-for="NewLead.RawCompanyNumber" />
                </label>

                <label class="auth-field">
                    <span>VAT Number</span>
                    <input asp-for="NewLead.RawVatNumber" />
                </label>

                <label class="auth-field">
                    <span>Website</span>
                    <input asp-for="NewLead.RawWebsiteUrl" />
                </label>

                <label class="auth-field">
                    <span>Lead Email</span>
                    <input asp-for="NewLead.RawContactEmailAddress" />
                </label>

                <label class="auth-field">
                    <span>Lead Phone</span>
                    <input asp-for="NewLead.RawContactPhoneNumber" />
                </label>

                <label class="auth-field auth-field--full auth-field--multiline">
                    <span>Raw Address</span>
                    <textarea asp-for="NewLead.RawAddressText"></textarea>
                </label>

                <label class="auth-field auth-field--full auth-field--multiline">
                    <span>Qualification Notes</span>
                    <textarea asp-for="NewLead.QualificationNotes"></textarea>
                </label>

                <label class="auth-field">
                    <span>Contact Name</span>
                    <input asp-for="NewLead.ContactName" />
                </label>

                <label class="auth-field">
                    <span>Contact Position</span>
                    <input asp-for="NewLead.ContactPosition" />
                </label>

                <label class="auth-field">
                    <span>Contact Email</span>
                    <input asp-for="NewLead.ContactEmailAddress" />
                </label>

                <label class="auth-field">
                    <span>Contact Phone</span>
                    <input asp-for="NewLead.ContactPhoneNumber" />
                </label>

                <label class="auth-field auth-field--full">
                    <span>LinkedIn URL</span>
                    <input asp-for="NewLead.ContactLinkedInUrl" />
                </label>
            </div>

            <div class="form-actions">
                <button type="submit" class="primary-action">Create lead</button>
            </div>
        </form>
    </div>
</dialog>
