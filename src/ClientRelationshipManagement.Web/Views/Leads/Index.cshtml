@model ClientRelationshipManagement.Web.Models.Leads.LeadsPageViewModel
@{
    ViewData["Title"] = "Leads";
}

<main class="page-shell">
    <section class="page-hero">
        <div>
            <h1>Leads</h1>
            <p class="lede">
                Review imported and manually added leads, then qualify the raw records before the
                workflow turns them into trusted companies and live opportunities.
            </p>
        </div>

        <div class="page-hero__actions">
            <button type="button" class="primary-action" onclick="document.getElementById('newLeadDialog').showModal()">New Lead</button>
            <a class="secondary-action" href="/Admin/Imports">Bulk Import</a>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.Notice))
    {
        <section class="notice-banner">
            <strong>Lead intake</strong>
            <p>@Model.Notice</p>
        </section>
    }

    <section class="data-panel">
        <div class="section-heading">
            <div>
                <h2>@Model.QueueTitle</h2>
                @if (Model.Companies.Count > 0 || Model.Scope is "candidates" or "suppressed")
                {
                    <p>Showing the highest-ranked 100 of @Model.MatchingCompanyCount.ToString("N0") matching companies.</p>
                }
            </div>
        </div>

        <form method="get" class="filter-bar">
            @if (!string.IsNullOrWhiteSpace(Model.Scope))
            {
                <input type="hidden" name="scope" value="@Model.Scope" />
            }
            @if (!string.IsNullOrWhiteSpace(Model.TaskFilter))
            {
                <input type="hidden" name="tasks" value="@Model.TaskFilter" />
            }
            <label class="auth-field auth-field--full">
                <span>Search</span>
                <input type="search" name="search" value="@Model.Search" placeholder="Company, contact, source, tenant" />
            </label>

            @if (Model.Scope is not ("candidates" or "suppressed"))
            {
                <label class="auth-field">
                    <span>Status</span>
                    <select name="status" asp-items="Model.StatusOptions"></select>
                </label>
            }

            <div class="filter-bar__actions">
                <button type="submit" class="primary-action">Filter</button>
                <a class="secondary-action" href="@(string.IsNullOrWhiteSpace(Model.Scope) ? "/Leads" : $"/Leads?scope={Model.Scope}")">Reset</a>
            </div>
        </form>

        @if (Model.Scope is "candidates" or "suppressed")
        {
            @if (Model.Companies.Count == 0)
            {
                <div class="empty-state">
                    <strong>No companies match the current filter.</strong>
                    <p>Try clearing the search or selecting another lead-generation view.</p>
                </div>
            }
            else
            {
                <div class="table-shell">
                    <table class="crm-table">
                        <thead>
                            <tr>
                                <th class="tree-grid__toggle-column"><span class="sr-only">Expand</span></th>
                                <th>Company</th>
                                <th>Company Number</th>
                                <th>Status</th>
                                <th>Ranking</th>
                                <th>Reason</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var company in Model.Companies)
                            {
                                <tr>
                                    <td class="tree-grid__toggle-cell"><button type="button" class="tree-grid__toggle" data-detail-expand="company-@company.Id" data-detail-url="/Companies/@company.Id/Details" aria-expanded="false" aria-label="Expand @company.CompanyName"><span aria-hidden="true"></span></button></td>
                                    <td>@company.CompanyName</td>
                                    <td>@company.CompanyNumber</td>
                                    <td>@company.CompanyStatus</td>
                                    <td>@(company.RankingScore?.ToString() ?? "Not ranked")</td>
                                    <td>@(string.IsNullOrWhiteSpace(company.SuppressionReason) ? "—" : company.SuppressionReason)</td>
                                </tr>
                                <tr class="tree-grid__detail-row" data-detail-row="company-@company.Id" hidden><td colspan="6"><div class="tree-grid__detail-host" data-detail-host="company-@company.Id"></div></td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
        else if (Model.Leads.Count == 0)
        {
            <div class="empty-state">
                <strong>No leads match the current filter.</strong>
                <p>Imported and manually created leads will appear here.</p>
            </div>
        }
        else
        {
            <div class="table-shell">
                <table class="crm-table">
                    <thead>
                        <tr>
                            <th class="tree-grid__toggle-column"><span class="sr-only">Expand</span></th>
                            <th>Company</th>
                            <th>Status</th>
                            <th>Source</th>
                            <th>Contact</th>
                            <th>Tenant</th>
                            <th>Linked</th>
                            <th>Created</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lead in Model.Leads)
                        {
                            <tr>
                                <td class="tree-grid__toggle-cell"><button type="button" class="tree-grid__toggle" data-detail-expand="lead-@lead.Id" data-detail-url="/Leads/@lead.Id/Details" aria-expanded="false" aria-label="Expand @lead.CompanyName"><span aria-hidden="true"></span></button></td>
                                <td>@lead.CompanyName</td>
                                <td>@lead.StatusLabel</td>
                                <td>@lead.SourceSystem</td>
                                <td>@(string.IsNullOrWhiteSpace(lead.ContactName) ? "Not set" : lead.ContactName)</td>
                                <td>@lead.TenantId</td>
                                <td>@lead.LinkedCompanyLabel</td>
                                <td>@lead.CreatedOnLabel</td>
                                <td class="table-actions">
                                    <a class="secondary-action" href="/Leads/Edit/@lead.Id">View lead</a>
                                </td>
                            </tr>
                            <tr class="tree-grid__detail-row" data-detail-row="lead-@lead.Id" hidden><td colspan="9"><div class="tree-grid__detail-host" data-detail-host="lead-@lead.Id"></div></td></tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</main>

<dialog id="newLeadDialog" class="crm-dialog crm-dialog--wide">
    <div class="crm-dialog__header">
        <div>
            <h3>New Lead</h3>
            <p>Create a single lead record and let the workflow take over from there.</p>
        </div>
        <button type="button" class="crm-dialog__close" onclick="document.getElementById('newLeadDialog').close()">Close</button>
    </div>

    <div class="crm-dialog__body">
        <form asp-action="Create" method="post" class="crm-form crm-form--compact">
            @Html.AntiForgeryToken()
            <div class="form-grid">
                <label class="auth-field">
                    <span>Tenant</span>
                    <input asp-for="NewLead.TenantId" />
                </label>

                <label class="auth-field">
                    <span>Source System</span>
                    <input asp-for="NewLead.SourceSystem" />
                </label>

                <label class="auth-field auth-field--full">
                    <span>Company Name</span>
                    <input asp-for="NewLead.RawCompanyName" />
                </label>

                <label class="auth-field">
                    <span>Trading Name</span>
                    <input asp-for="NewLead.RawTradingName" />
                </label>

                <label class="auth-field">
                    <span>Company Number</span>
                    <input asp-for="NewLead.RawCompanyNumber" />
                </label>

                <label class="auth-field">
                    <span>VAT Number</span>
                    <input asp-for="NewLead.RawVatNumber" />
                </label>

                <label class="auth-field">
                    <span>Website</span>
                    <input asp-for="NewLead.RawWebsiteUrl" />
                </label>

                <label class="auth-field">
                    <span>Lead Email</span>
                    <input asp-for="NewLead.RawContactEmailAddress" />
                </label>

                <label class="auth-field">
                    <span>Lead Phone</span>
                    <input asp-for="NewLead.RawContactPhoneNumber" />
                </label>

                <label class="auth-field auth-field--full auth-field--multiline">
                    <span>Raw Address</span>
                    <textarea asp-for="NewLead.RawAddressText"></textarea>
                </label>

                <label class="auth-field auth-field--full auth-field--multiline">
                    <span>Qualification Notes</span>
                    <textarea asp-for="NewLead.QualificationNotes"></textarea>
                </label>

                <label class="auth-field">
                    <span>Contact Name</span>
                    <input asp-for="NewLead.ContactName" />
                </label>

                <label class="auth-field">
                    <span>Contact Position</span>
                    <input asp-for="NewLead.ContactPosition" />
                </label>

                <label class="auth-field">
                    <span>Contact Email</span>
                    <input asp-for="NewLead.ContactEmailAddress" />
                </label>

                <label class="auth-field">
                    <span>Contact Phone</span>
                    <input asp-for="NewLead.ContactPhoneNumber" />
                </label>

                <label class="auth-field auth-field--full">
                    <span>LinkedIn URL</span>
                    <input asp-for="NewLead.ContactLinkedInUrl" />
                </label>
            </div>

            <div class="form-actions">
                <button type="submit" class="primary-action">Create lead</button>
            </div>
        </form>
    </div>
</dialog>

<script>
    (() => {
        const initialiseTabs = (host) => host.querySelectorAll("[data-detail-tab]").forEach((tab) => tab.addEventListener("click", () => {
            host.querySelectorAll("[data-detail-tab]").forEach((candidate) => {
                const active = candidate === tab;
                candidate.classList.toggle("is-active", active);
                candidate.setAttribute("aria-selected", active ? "true" : "false");
            });
            host.querySelectorAll("[data-detail-panel]").forEach((panel) => panel.hidden = panel.dataset.detailPanel !== tab.dataset.detailTab);
        }));

        document.querySelectorAll("[data-detail-expand]").forEach((button) => button.addEventListener("click", async () => {
            const key = button.dataset.detailExpand;
            const row = document.querySelector(`[data-detail-row="${key}"]`);
            const host = row.querySelector("[data-detail-host]");
            const opening = row.hidden;
            row.hidden = !opening;
            button.setAttribute("aria-expanded", opening ? "true" : "false");
            if (!opening || host.dataset.loaded === "true") return;
            host.innerHTML = '<p class="crm-muted">Loading details…</p>';
            try {
                const response = await fetch(button.dataset.detailUrl, { headers: { "X-Requested-With": "XMLHttpRequest" } });
                if (!response.ok) throw new Error();
                host.innerHTML = await response.text();
                host.dataset.loaded = "true";
                initialiseTabs(host);
            } catch {
                host.innerHTML = '<div class="empty-state empty-state--compact"><strong>Details could not be loaded.</strong><p>Collapse and try again.</p></div>';
            }
        }));
    })();
</script>
