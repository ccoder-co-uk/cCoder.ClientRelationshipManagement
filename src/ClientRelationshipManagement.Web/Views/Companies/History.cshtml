@model ClientRelationshipManagement.Web.Models.Companies.CompanyHistoryPageViewModel
@{
    ViewData["Title"] = $"{Model.CompanyName} History";
}

<main class="page-shell">
    <section class="page-hero">
        <div>
            <h1>@Model.CompanyName</h1>
            <p class="lede">The company’s end-to-end evidence and decision history across leads, opportunities, and client maintenance.</p>
        </div>
        <div class="page-hero__actions">
            <a class="secondary-action" href="javascript:history.back()">Back</a>
        </div>
    </section>

    <section class="workspace-card">
        <div class="workspace-card__stats">
            <span>Company number: @(string.IsNullOrWhiteSpace(Model.CompanyNumber) ? "Not recorded" : Model.CompanyNumber)</span>
            <span>Status: @(string.IsNullOrWhiteSpace(Model.CompanyStatus) ? "Not recorded" : Model.CompanyStatus)</span>
            <span>@Model.Items.Count recent history item@(Model.Items.Count == 1 ? "" : "s")</span>
        </div>
    </section>

    <section class="company-history" aria-label="Company history">
        @if (Model.Items.Count == 0)
        {
            <div class="empty-state">
                <strong>No lifecycle history has been recorded yet.</strong>
                <p>Completed process steps will appear here automatically.</p>
            </div>
        }
        else
        {
            @foreach (var item in Model.Items)
            {
                <article class="company-history__item company-history__item--@item.Lane.ToLowerInvariant()">
                    <time datetime="@item.OccurredOn.ToString("O")">@item.OccurredOn.ToLocalTime().ToString("dd MMM yyyy HH:mm")</time>
                    <div>
                        <div class="company-history__meta">
                            <span>@item.Lane</span>
                            <span>@item.EventType</span>
                            @if (!string.IsNullOrWhiteSpace(item.Confidence))
                            {
                                <span>@item.Confidence confidence</span>
                            }
                        </div>
                        <h2>@item.Summary</h2>
                        @if (!string.IsNullOrWhiteSpace(item.FactKey))
                        {
                            <p><strong>@item.FactKey</strong>: @item.FactValue</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.Details) && item.Details != item.FactValue)
                        {
                            <p>@item.Details</p>
                        }
                    </div>
                </article>
            }
        }
    </section>
</main>
